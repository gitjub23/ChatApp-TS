<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat" Height="400" Width="600"
        Closing="Window_Closing"
        Background="#FF2D2D30"
        FontFamily="Segoe UI"
        Foreground="White">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="180"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Row: Login Controls -->
        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center" HorizontalAlignment="Left">

            <!-- Username Field -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="/Images/username2.png" Width="20" Height="20" VerticalAlignment="Center" Margin="10,0" ToolTip="Username"/>
                <TextBox x:Name="UsernameBox" Width="120" Padding="5"
                         Background="#FF3E3E42" BorderBrush="#FF515151" Foreground="White"
                         ToolTip="Enter the username"/>
            </StackPanel>

            <!-- Password Field with Toggle -->
            <!-- Password Field with Toggle Eye Button -->
<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
    <Image Source="/Images/password2.png" Width="20" Height="20" VerticalAlignment="Center" Margin="10,0" ToolTip="Password"/>

    <!-- Grid holding PasswordBox, Visible TextBox and Eye Toggle -->
    <Grid Width="120" Height="30">
        <PasswordBox x:Name="PasswordBox"
                     Padding="5,0,30,0"
                     Background="#FF3E3E42"
                     BorderBrush="#FF515151"
                     Foreground="White"
                     VerticalContentAlignment="Center"/>
        
        <TextBox x:Name="VisiblePasswordBox"
                 Padding="5,0,30,0"
                 Background="#FF3E3E42"
                 BorderBrush="#FF515151"
                 Foreground="White"
                 Visibility="Collapsed"
                 VerticalContentAlignment="Center"/>

        <ToggleButton x:Name="TogglePasswordVisibility"
              Width="24"
              Height="24"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Margin="0,0,5,0"
              Background="Transparent"
              BorderBrush="{x:Null}"
              Click="TogglePasswordVisibility_Click">
                        
             <TextBlock x:Name="PasswordToggleIcon"
               Text="👁"
               FontSize="16"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" ToolTip="Show password"/>
        </ToggleButton>

    </Grid>
</StackPanel>


            <!-- Buttons -->
            <Button Content="Connect" Click="ConnectButton_Click" Width="90"
                    Background="#FF007ACC" BorderThickness="0" Foreground="White" FontWeight="Bold" Margin="20,0,10,0"/>

            <Button Content="Register" Click="RegisterButton_Click" Width="90"
                    Background="#FF007ACC" BorderThickness="0" Foreground="White" FontWeight="Bold" Margin="10,0"/>
        </StackPanel>

        <!-- Chat Text Box -->
        <TextBox x:Name="ChatBox"
                 Grid.Row="1" Grid.Column="0"
                 VerticalScrollBarVisibility="Auto"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 Padding="10"
                 Background="#FF1E1E1E"
                 BorderBrush="#FF515151"
                 Foreground="White"
                 FontSize="14"
                 Margin="0,0,15,0"/>

        <!-- Users List -->
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0">
            <TextBlock Text="Online Users"
                       FontWeight="Bold"
                       FontSize="16"
                       Margin="0,0,0,8"
                       Foreground="LightGray"
                       HorizontalAlignment="Center"/>
            <ListBox x:Name="UserList"
                     BorderBrush="#FF515151"
                     Background="#FF1E1E1E"
                     Foreground="White"
                     FontSize="14"
                     SelectionMode="Single"
                     ToolTip="Select a user to send a private message"/>
        </StackPanel>

        <!-- Bottom Row: Message Input and Buttons -->
        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Message Input -->
            <TextBox x:Name="MessageBox"
                     Grid.Column="0"
                     Height="30"
                     VerticalAlignment="Center"
                     Padding="5"
                     Background="#FF3E3E42"
                     BorderBrush="#FF515151"
                     Foreground="White"
                     FontSize="14"
                     KeyDown="MessageBox_KeyDown"/>

            <!-- Buttons -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                <Button Width="40" Height="40" Margin="0,0,10,0"
                        Click="SendButton_Click"
                        ToolTip="Send Message"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Padding="0">
                    <Image Source="Images/send.png" Stretch="Uniform"/>
                </Button>

                <Button Width="40" Height="40" Margin="0,0,10,0"
                        Click="SendFileButton_Click"
                        ToolTip="Send a file"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Padding="0">
                    <Image Source="Images/attach.png" Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
